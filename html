<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vaultly — Save flexibly. Earn daily.</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --navy-950: #10192f;
    --navy-900: #16223f;
    --navy-800: #1f2f52;
    --cream: #f7f5ef;
    --paper: #fffdf9;
    --amber: #e8a548;
    --amber-deep: #c9812b;
    --moss: #4c8a6a;
    --moss-deep: #396b50;
    --red: #c0533f;
    --slate: #4a5164;
    --slate-light: #8890a3;
    --line: #e4e0d5;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background: var(--cream);
    color: var(--navy-950);
    font-family: 'Inter', sans-serif;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  h1, h2, h3 { font-family: 'Fraunces', serif; font-weight: 600; letter-spacing: -0.01em; color: var(--navy-950); }
  .num { font-family: 'IBM Plex Mono', monospace; }
  button { font-family: 'Inter', sans-serif; cursor: pointer; }
  input { font-family: 'Inter', sans-serif; }
  :focus-visible { outline: 2px solid var(--amber-deep); outline-offset: 3px; }
  @media (prefers-reduced-motion: reduce) { * { animation-duration: 0.01ms !important; transition-duration: 0.01ms !important; } }

  .screen { display: none; min-height: 100vh; }
  .screen.active { display: block; }

  /* ---------- Auth screens ---------- */
  .auth-wrap {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 32px 20px;
  }
  .auth-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: 44px 40px;
    width: 100%;
    max-width: 400px;
    box-shadow: 0 30px 60px -30px rgba(16,25,47,0.2);
  }
  .auth-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: 'Fraunces', serif;
    font-weight: 600;
    font-size: 20px;
    margin-bottom: 28px;
  }
  .logo-mark {
    width: 30px; height: 30px;
    border-radius: 8px;
    background: linear-gradient(155deg, var(--navy-900), var(--navy-800));
    position: relative;
    flex-shrink: 0;
  }
  .logo-mark::after {
    content: '';
    position: absolute;
    left: 8px; top: 7px;
    width: 14px; height: 14px;
    border: 2px solid var(--amber);
    border-radius: 4px;
    border-bottom-color: transparent;
    border-right-color: transparent;
    transform: rotate(45deg);
  }
  .auth-card h1 { font-size: 26px; margin-bottom: 6px; }
  .auth-card .sub { color: var(--slate); font-size: 14.5px; margin-bottom: 28px; }

  .field { margin-bottom: 18px; }
  .field label { display: block; font-size: 13px; font-weight: 600; color: var(--slate); margin-bottom: 7px; }
  .field input {
    width: 100%;
    padding: 12px 14px;
    border: 1.5px solid var(--line);
    border-radius: 10px;
    font-size: 14.5px;
    background: var(--cream);
    color: var(--navy-950);
    transition: border-color 0.15s ease;
  }
  .field input:focus { border-color: var(--navy-800); background: var(--paper); }
  .field input.err { border-color: var(--red); }
  .field .msg { font-size: 12.5px; color: var(--red); margin-top: 6px; min-height: 15px; }
  .field .hint { font-size: 12px; color: var(--slate-light); margin-top: 6px; }

  .btn-block {
    width: 100%;
    background: var(--navy-950);
    color: var(--paper);
    border: none;
    padding: 14px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 15px;
    margin-top: 6px;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .btn-block:hover { background: var(--navy-800); transform: translateY(-1px); }

  .switch-line {
    text-align: center;
    font-size: 14px;
    color: var(--slate);
    margin-top: 22px;
  }
  .switch-line button {
    background: none;
    border: none;
    color: var(--amber-deep);
    font-weight: 600;
    font-size: 14px;
    padding: 0;
  }

  .form-alert {
    background: #fbeee9;
    border: 1px solid #edc8bb;
    color: var(--red);
    font-size: 13.5px;
    padding: 10px 14px;
    border-radius: 10px;
    margin-bottom: 18px;
    display: none;
  }
  .form-alert.show { display: block; }

  /* ---------- Dashboard shell ---------- */
  .app-nav {
    background: var(--navy-950);
    color: var(--paper);
    padding: 18px 0;
  }
  .app-nav .wrap {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .app-nav .auth-logo { margin: 0; color: var(--paper); }
  .app-nav .user-chip {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
  }
  .avatar {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: var(--amber);
    color: var(--navy-950);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 13px;
  }
  .logout-btn {
    background: rgba(247,245,239,0.1);
    border: 1px solid rgba(247,245,239,0.2);
    color: var(--paper);
    padding: 8px 16px;
    border-radius: 100px;
    font-size: 13px;
    font-weight: 600;
  }

  .dash-wrap { max-width: 900px; margin: 0 auto; padding: 40px 24px 80px; }

  .balance-card {
    background: linear-gradient(165deg, var(--navy-950), var(--navy-800));
    border-radius: 24px;
    padding: 36px;
    color: var(--paper);
    position: relative;
    overflow: hidden;
    margin-bottom: 28px;
  }
  .balance-card::before {
    content: '';
    position: absolute;
    top: -60px; right: -60px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(232,165,72,0.18), transparent 70%);
  }
  .balance-card .label { font-size: 13px; color: rgba(247,245,239,0.6); margin-bottom: 8px; }
  .balance-card .amount { font-size: 42px; font-weight: 500; display: flex; align-items: baseline; gap: 2px; margin-bottom: 4px; }
  .balance-card .amount .cents { font-size: 24px; color: rgba(247,245,239,0.75); }
  .accruing { display: flex; align-items: center; gap: 7px; font-size: 13px; color: var(--amber); margin-bottom: 26px; }
  .accruing .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--amber); animation: pulse 1.6s ease-in-out infinite; }
  @keyframes pulse { 0%, 100% { opacity: 1; transform: scale(1); } 50% { opacity: 0.4; transform: scale(0.7); } }
  .card-actions { display: flex; gap: 12px; margin-top: 10px; }
  .card-actions button {
    flex: 1;
    padding: 13px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 14px;
    border: none;
  }
  .btn-deposit { background: var(--amber); color: var(--navy-950); }
  .btn-withdraw { background: rgba(247,245,239,0.1); border: 1px solid rgba(247,245,239,0.2) !important; color: var(--paper); }

  .stat-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; margin-bottom: 28px; }
  .stat {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 20px;
  }
  .stat .k { font-size: 12.5px; color: var(--slate-light); margin-bottom: 6px; }
  .stat .v { font-size: 20px; font-family: 'IBM Plex Mono', monospace; }
  @media (max-width: 640px) { .stat-row { grid-template-columns: 1fr; } }

  .panel {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 8px 0;
  }
  .panel h3 { font-size: 16px; padding: 18px 22px 6px; }
  .txn {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 22px;
    border-top: 1px solid var(--line);
    font-size: 14px;
  }
  .txn .desc { display: flex; align-items: center; gap: 12px; }
  .txn-icon {
    width: 34px; height: 34px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 15px;
    flex-shrink: 0;
  }
  .txn-icon.in { background: #e8f2ec; color: var(--moss-deep); }
  .txn-icon.out { background: #f4ece2; color: var(--amber-deep); }
  .txn .meta .label { font-weight: 500; }
  .txn .meta .date { color: var(--slate-light); font-size: 12.5px; margin-top: 2px; }
  .txn .amt { font-family: 'IBM Plex Mono', monospace; font-weight: 500; }
  .txn .amt.in { color: var(--moss-deep); }
  .txn .amt.out { color: var(--navy-950); }
  .empty-txn { padding: 30px 22px; text-align: center; color: var(--slate-light); font-size: 14px; }

  /* ---------- Modal ---------- */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(16,25,47,0.5);
    align-items: center;
    justify-content: center;
    padding: 20px;
    z-index: 100;
  }
  .modal-overlay.show { display: flex; }
  .modal {
    background: var(--paper);
    border-radius: 20px;
    padding: 32px;
    width: 100%;
    max-width: 360px;
  }
  .modal h3 { font-size: 20px; margin-bottom: 6px; }
  .modal .sub { color: var(--slate); font-size: 14px; margin-bottom: 22px; }
  .modal .modal-actions { display: flex; gap: 10px; margin-top: 20px; }
  .btn-secondary {
    flex: 1;
    background: var(--cream);
    border: 1px solid var(--line);
    color: var(--navy-950);
    padding: 13px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 14px;
  }
  .btn-primary-modal {
    flex: 1;
    background: var(--navy-950);
    color: var(--paper);
    border: none;
    padding: 13px;
    border-radius: 100px;
    font-weight: 600;
    font-size: 14px;
  }

  .toast {
    position: fixed;
    bottom: 28px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--navy-950);
    color: var(--paper);
    padding: 13px 22px;
    border-radius: 100px;
    font-size: 14px;
    font-weight: 500;
    opacity: 0;
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    z-index: 200;
  }
  .toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
</style>
</head>
<body>

<!-- ============ SIGNUP ============ -->
<div class="screen active" id="screen-signup">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-logo"><span class="logo-mark"></span>Vaultly</div>
      <h1>Create your account</h1>
      <p class="sub">Start earning daily interest on your savings.</p>
      <div class="form-alert" id="signup-alert"></div>
      <form id="signup-form" novalidate>
        <div class="field">
          <label for="su-name">Full name</label>
          <input type="text" id="su-name" autocomplete="name">
          <div class="msg" id="su-name-msg"></div>
        </div>
        <div class="field">
          <label for="su-email">Email</label>
          <input type="email" id="su-email" autocomplete="email">
          <div class="msg" id="su-email-msg"></div>
        </div>
        <div class="field">
          <label for="su-password">Password</label>
          <input type="password" id="su-password" autocomplete="new-password">
          <div class="hint">At least 8 characters.</div>
          <div class="msg" id="su-password-msg"></div>
        </div>
        <div class="field">
          <label for="su-confirm">Confirm password</label>
          <input type="password" id="su-confirm" autocomplete="new-password">
          <div class="msg" id="su-confirm-msg"></div>
        </div>
        <button type="submit" class="btn-block">Create account</button>
      </form>
      <div class="switch-line">Already have an account? <button type="button" id="go-login">Log in</button></div>
    </div>
  </div>
</div>

<!-- ============ LOGIN ============ -->
<div class="screen" id="screen-login">
  <div class="auth-wrap">
    <div class="auth-card">
      <div class="auth-logo"><span class="logo-mark"></span>Vaultly</div>
      <h1>Welcome back</h1>
      <p class="sub">Log in to your Vaultly account.</p>
      <div class="form-alert" id="login-alert"></div>
      <form id="login-form" novalidate>
        <div class="field">
          <label for="li-email">Email</label>
          <input type="email" id="li-email" autocomplete="email">
          <div class="msg" id="li-email-msg"></div>
        </div>
        <div class="field">
          <label for="li-password">Password</label>
          <input type="password" id="li-password" autocomplete="current-password">
          <div class="msg" id="li-password-msg"></div>
        </div>
        <button type="submit" class="btn-block">Log in</button>
      </form>
      <div class="switch-line">Don't have an account? <button type="button" id="go-signup">Create one</button></div>
    </div>
  </div>
</div>

<!-- ============ DASHBOARD ============ -->
<div class="screen" id="screen-dash">
  <nav class="app-nav">
    <div class="wrap">
      <div class="auth-logo"><span class="logo-mark"></span>Vaultly</div>
      <div class="user-chip">
        <div class="avatar" id="dash-avatar">V</div>
        <span id="dash-name">—</span>
        <button class="logout-btn" id="logout-btn">Log out</button>
      </div>
    </div>
  </nav>

  <div class="dash-wrap">
    <div class="balance-card">
      <div class="label">Available balance</div>
      <div class="amount"><span class="num" id="balanceWhole">0</span><span class="cents num" id="balanceCents">.00</span></div>
      <div class="accruing"><span class="dot"></span>Earning interest now</div>
      <div class="card-actions">
        <button class="btn-deposit" id="open-deposit">Deposit</button>
        <button class="btn-withdraw" id="open-withdraw">Withdraw</button>
      </div>
    </div>

    <div class="stat-row">
      <div class="stat"><div class="k">Current rate</div><div class="v">8.0% p.a.</div></div>
      <div class="stat"><div class="k">Interest earned (demo)</div><div class="v num" id="stat-interest">₦0.00</div></div>
      <div class="stat"><div class="k">Minimum withdrawal</div><div class="v">None</div></div>
    </div>

    <div class="panel">
      <h3>Recent activity</h3>
      <div id="txn-list"><div class="empty-txn">No transactions yet — make a deposit to get started.</div></div>
    </div>
  </div>
</div>

<!-- ============ MODALS ============ -->
<div class="modal-overlay" id="deposit-overlay">
  <div class="modal">
    <h3>Deposit funds</h3>
    <p class="sub">This is a demo balance — no real money moves here.</p>
    <div class="field">
      <label for="deposit-amount">Amount (₦)</label>
      <input type="number" id="deposit-amount" min="1" placeholder="e.g. 5000">
      <div class="msg" id="deposit-msg"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-secondary" id="cancel-deposit">Cancel</button>
      <button class="btn-primary-modal" id="confirm-deposit">Deposit</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="withdraw-overlay">
  <div class="modal">
    <h3>Withdraw funds</h3>
    <p class="sub">No minimum, no fee. Demo balance only.</p>
    <div class="field">
      <label for="withdraw-amount">Amount (₦)</label>
      <input type="number" id="withdraw-amount" min="1" placeholder="e.g. 2000">
      <div class="msg" id="withdraw-msg"></div>
    </div>
    <div class="modal-actions">
      <button class="btn-secondary" id="cancel-withdraw">Cancel</button>
      <button class="btn-primary-modal" id="confirm-withdraw">Withdraw</button>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script>
(function() {
  // ---------- Supabase config ----------
  // Fill these in from your Supabase project: Settings -> API
  var SUPABASE_URL = "https://tvesfxatgmzxagdimzgl.supabase.co";
  var SUPABASE_ANON_KEY = "sb_publishable_gdP0KZ1z3AHmLLOMiVa3bA_R0on1143";

  var supabaseClient = null;
  var supabaseConfigured = SUPABASE_URL.indexOf("YOUR_SUPABASE") === -1 && SUPABASE_ANON_KEY.indexOf("YOUR_SUPABASE") === -1;
  if (supabaseConfigured && window.supabase) {
    supabaseClient = window.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  }

  // ---------- Local state (balance/transactions are still a demo layer) ----------
  var session = null; // current logged-in user's email
  var currentName = null;
  var balanceKobo = 0;
  var interestEarnedKobo = 0;
  var transactions = [];
  var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  var accrualTimer = null;

  function $(id) { return document.getElementById(id); }

  function showScreen(id) {
    document.querySelectorAll('.screen').forEach(function(s) { s.classList.remove('active'); });
    $(id).classList.add('active');
  }

  function showToast(msg) {
    var t = $('toast');
    t.textContent = msg;
    t.classList.add('show');
    setTimeout(function() { t.classList.remove('show'); }, 2200);
  }

  function clearMsgs(form) {
    form.querySelectorAll('.msg').forEach(function(m) { m.textContent = ''; });
    form.querySelectorAll('input').forEach(function(i) { i.classList.remove('err'); });
  }

  function setErr(inputId, msgId, text) {
    $(inputId).classList.add('err');
    $(msgId).textContent = text;
  }

  function isValidEmail(v) { return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v); }

  // ---------- Signup ----------
  $('signup-form').addEventListener('submit', function(e) {
    e.preventDefault();
    clearMsgs(this);
    var alertEl = $('signup-alert');
    alertEl.classList.remove('show');
    var name = $('su-name').value.trim();
    var email = $('su-email').value.trim().toLowerCase();
    var pw = $('su-password').value;
    var confirm = $('su-confirm').value;
    var valid = true;

    if (!name) { setErr('su-name', 'su-name-msg', 'Enter your full name.'); valid = false; }
    if (!email || !isValidEmail(email)) { setErr('su-email', 'su-email-msg', 'Enter a valid email address.'); valid = false; }
    if (!pw || pw.length < 8) { setErr('su-password', 'su-password-msg', 'Password must be at least 8 characters.'); valid = false; }
    if (confirm !== pw || !confirm) { setErr('su-confirm', 'su-confirm-msg', 'Passwords do not match.'); valid = false; }
    if (!valid) return;

    if (!supabaseConfigured) {
      alertEl.textContent = 'Supabase isn\'t connected yet — add your Project URL and anon key at the top of the script to enable real accounts.';
      alertEl.classList.add('show');
      return;
    }

    var submitBtn = this.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    supabaseClient.auth.signUp({
      email: email,
      password: pw,
      options: { data: { full_name: name } }
    }).then(function(result) {
      submitBtn.disabled = false;
      if (result.error) {
        alertEl.textContent = result.error.message;
        alertEl.classList.add('show');
        return;
      }
      session = email;
      currentName = name;
      balanceKobo = 0;
      interestEarnedKobo = 0;
      transactions = [];
      enterDashboard();
      recordSignInEvent(email);
    });
  });

  // ---------- Login ----------
  $('login-form').addEventListener('submit', function(e) {
    e.preventDefault();
    clearMsgs(this);
    var alertEl = $('login-alert');
    alertEl.classList.remove('show');
    var email = $('li-email').value.trim().toLowerCase();
    var pw = $('li-password').value;
    var valid = true;

    if (!email || !isValidEmail(email)) { setErr('li-email', 'li-email-msg', 'Enter a valid email address.'); valid = false; }
    if (!pw) { setErr('li-password', 'li-password-msg', 'Enter your password.'); valid = false; }
    if (!valid) return;

    if (!supabaseConfigured) {
      alertEl.textContent = 'Supabase isn\'t connected yet — add your Project URL and anon key at the top of the script to enable real accounts.';
      alertEl.classList.add('show');
      return;
    }

    var submitBtn = this.querySelector('button[type="submit"]');
    submitBtn.disabled = true;
    supabaseClient.auth.signInWithPassword({ email: email, password: pw }).then(function(result) {
      submitBtn.disabled = false;
      if (result.error) {
        alertEl.textContent = 'Incorrect email or password.';
        alertEl.classList.add('show');
        return;
      }
      session = email;
      currentName = (result.data.user.user_metadata && result.data.user.user_metadata.full_name) || email;
      enterDashboard();
      recordSignInEvent(email);
    });
  });

  // Writes a row that the sign_in_events database webhook watches,
  // which triggers the notify-on-signin Edge Function to email you.
  function recordSignInEvent(email) {
    if (!supabaseConfigured) return;
    supabaseClient.from('sign_in_events').insert({ user_email: email }).then(function(result) {
      if (result.error) console.error('Could not record sign-in event:', result.error.message);
    });
  }

  $('go-login').addEventListener('click', function() { showScreen('screen-login'); });
  $('go-signup').addEventListener('click', function() { showScreen('screen-signup'); });

  $('logout-btn').addEventListener('click', function() {
    session = null;
    if (accrualTimer) clearInterval(accrualTimer);
    if (supabaseConfigured) supabaseClient.auth.signOut();
    $('signup-form').reset();
    $('login-form').reset();
    showScreen('screen-login');
  });

  // ---------- Dashboard ----------
  function enterDashboard() {
    var name = currentName || session;
    $('dash-name').textContent = name;
    $('dash-avatar').textContent = name.trim().charAt(0).toUpperCase() || 'V';
    renderBalance();
    renderTxns();
    showScreen('screen-dash');
    startAccrual();
  }

  function renderBalance() {
    var naira = Math.floor(balanceKobo / 100);
    var kobo = balanceKobo % 100;
    $('balanceWhole').textContent = naira.toLocaleString('en-NG');
    $('balanceCents').textContent = '.' + String(kobo).padStart(2, '0');
    $('stat-interest').textContent = '₦' + (interestEarnedKobo / 100).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
  }

  function renderTxns() {
    var list = $('txn-list');
    if (!transactions.length) {
      list.innerHTML = '<div class="empty-txn">No transactions yet — make a deposit to get started.</div>';
      return;
    }
    list.innerHTML = transactions.slice().reverse().map(function(t) {
      var isIn = t.type === 'deposit' || t.type === 'interest';
      var icon = t.type === 'deposit' ? '↓' : t.type === 'withdraw' ? '↑' : '✦';
      var label = t.type === 'deposit' ? 'Deposit' : t.type === 'withdraw' ? 'Withdrawal' : 'Interest earned';
      return '<div class="txn">' +
        '<div class="desc"><div class="txn-icon ' + (isIn ? 'in' : 'out') + '">' + icon + '</div>' +
        '<div class="meta"><div class="label">' + label + '</div><div class="date">' + t.date + '</div></div></div>' +
        '<div class="amt ' + (isIn ? 'in' : 'out') + '">' + (isIn ? '+' : '−') + '₦' + (t.amountKobo / 100).toLocaleString('en-NG', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + '</div>' +
        '</div>';
    }).join('');
  }

  function nowLabel() {
    return new Date().toLocaleString('en-NG', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' });
  }

  function startAccrual() {
    if (accrualTimer) clearInterval(accrualTimer);
    if (reduceMotion) return;
    accrualTimer = setInterval(function() {
      if (!session || balanceKobo <= 0) return;
      // illustrative accrual only — not a real interest calculation
      var accrued = 1;
      balanceKobo += accrued;
      interestEarnedKobo += accrued;
      renderBalance();
    }, 1400);
  }

  // ---------- Deposit modal ----------
  $('open-deposit').addEventListener('click', function() {
    $('deposit-amount').value = '';
    $('deposit-msg').textContent = '';
    $('deposit-overlay').classList.add('show');
  });
  $('cancel-deposit').addEventListener('click', function() { $('deposit-overlay').classList.remove('show'); });
  $('confirm-deposit').addEventListener('click', function() {
    var val = parseFloat($('deposit-amount').value);
    if (!val || val <= 0) { $('deposit-msg').textContent = 'Enter a valid amount.'; return; }
    var kobo = Math.round(val * 100);
    balanceKobo += kobo;
    transactions.push({ type: 'deposit', amountKobo: kobo, date: nowLabel() });
    renderBalance();
    renderTxns();
    $('deposit-overlay').classList.remove('show');
    showToast('Deposit of ₦' + val.toLocaleString('en-NG') + ' added.');
  });

  // ---------- Withdraw modal ----------
  $('open-withdraw').addEventListener('click', function() {
    $('withdraw-amount').value = '';
    $('withdraw-msg').textContent = '';
    $('withdraw-overlay').classList.add('show');
  });
  $('cancel-withdraw').addEventListener('click', function() { $('withdraw-overlay').classList.remove('show'); });
  $('confirm-withdraw').addEventListener('click', function() {
    var val = parseFloat($('withdraw-amount').value);
    var kobo = Math.round(val * 100);
    if (!val || val <= 0) { $('withdraw-msg').textContent = 'Enter a valid amount.'; return; }
    if (kobo > balanceKobo) { $('withdraw-msg').textContent = 'Insufficient balance.'; return; }
    balanceKobo -= kobo;
    transactions.push({ type: 'withdraw', amountKobo: kobo, date: nowLabel() });
    renderBalance();
    renderTxns();
    $('withdraw-overlay').classList.remove('show');
    showToast('Withdrawal of ₦' + val.toLocaleString('en-NG') + ' requested.');
  });

  // Close modals on overlay click
  [$('deposit-overlay'), $('withdraw-overlay')].forEach(function(ov) {
    ov.addEventListener('click', function(e) { if (e.target === ov) ov.classList.remove('show'); });
  });
})();
</script>

</body>
</html>
